// =====================================================================
// model/03_solve/<MODEL_NAME>/<MODEL_NAME>.mod
// 语言版本：Dynare 6.x
// 模型：<MODEL_NAME>
// spec：model/01_setup/<MODEL_NAME>/spec.md
// 创建：<author> <YYYY-MM-DD>
// =====================================================================

// 重要：禁止在注释中出现 /*；Dynare 会把 /* 当块注释起点而吞内容。
// 路径写为 "output/tables/" 而非 "output/tables/*"。

@#define MODEL = "<MODEL_NAME>"

// ---------------------------------------------------------------------
// 1. 内生变量声明
// ---------------------------------------------------------------------
var
  c   // 消费
  k   // 资本
  y   // 产出
  z   // TFP（对数偏离）
;

// ---------------------------------------------------------------------
// 2. 外生冲击声明
// ---------------------------------------------------------------------
varexo
  eps_z   // TFP 创新
;

// ---------------------------------------------------------------------
// 3. 参数声明
// ---------------------------------------------------------------------
parameters
  beta    // 折现因子
  alpha   // 资本份额
  delta   // 折旧率
  rho_z   // TFP 持续性
  sigma_z // TFP 创新标准差
;

// 参数赋值（来自校准表）
@#include "../../02_calibrate/<MODEL_NAME>/parameters.mod"

// ---------------------------------------------------------------------
// 4. 模型方程
// ---------------------------------------------------------------------
model;
  // (1) 消费欧拉方程
  1/c = beta * (1/c(+1)) * (alpha*exp(z(+1))*k^(alpha-1) + 1 - delta);

  // (2) 资源约束
  c + k = (1-delta)*k(-1) + y;

  // (3) 生产函数
  y = exp(z) * k(-1)^alpha;

  // (4) TFP 过程
  z = rho_z * z(-1) + eps_z;
end;

// ---------------------------------------------------------------------
// 5. 解析稳态（若可用）
// ---------------------------------------------------------------------
steady_state_model;
  z = 0;
  k = ((1/beta - 1 + delta) / alpha)^(1/(alpha-1));
  y = k^alpha;
  c = y - delta*k;
end;

// ---------------------------------------------------------------------
// 6. 冲击协方差
// ---------------------------------------------------------------------
shocks;
  var eps_z; stderr sigma_z;
end;

// ---------------------------------------------------------------------
// 7. 求解与仿真
// ---------------------------------------------------------------------
steady;
check;

stoch_simul(order=1, irf=40, periods=0, nograph) c k y z;

// ---------------------------------------------------------------------
// 8. 后处理：保存检查点
// 由 wrapper 脚本完成，见 scripts/run_dynare.sh
// ---------------------------------------------------------------------
